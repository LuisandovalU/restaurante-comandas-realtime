{
  "name": "restaurante-comandas",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema de Gestión de Comandas en Tiempo Real — El Rincón del Parque",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-8080}",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "lint": "biome lint ./src ./convex",
    "format": "biome format --write ./src ./convex",
    "check": "biome check --write ./src ./convex",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "convex": "^1.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "nitro": "^3.0.260311-beta",
    "typescript": "^5.7.0",
    "vite": "^8.0.14",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  }
}